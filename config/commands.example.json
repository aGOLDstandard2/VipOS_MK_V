{
  "commands": [
    {
      "command": "!vipos",
      "roles": ["broadcaster", "mod"],
      "cooldownSeconds": 5,
      "actions": [
        { "type": "overlay.alert", "message": "VipOS MK V is online." },
        { "type": "chat.say", "message": "VipOS MK V is online.", "reply": true }
      ]
    },
    {
      "command": "!alert",
      "roles": ["broadcaster", "mod", "vip"],
      "cooldownSeconds": 5,
      "actions": [
        { "type": "overlay.alert", "message": "{after}" }
      ]
    },
    {
      "command": "!border",
      "roles": ["broadcaster", "mod"],
      "cooldownSeconds": 5,
      "actions": [
        { "type": "overlay.emit", "event": "bg-random" }
      ]
    },
    {
      "command": "!brb",
      "roles": ["broadcaster", "mod"],
      "cooldownSeconds": 10,
      "actions": [
        { "type": "obs.scene", "scene": "BRB" }
      ]
    },
    {
      "command": "!sfx",
      "roles": ["broadcaster", "mod"],
      "cooldownSeconds": 5,
      "actions": [
        { "type": "sound.pickRandom", "contextKey": "sfx" },
        { "type": "overlay.alert", "message": "{sfx.text}" },
        { "type": "sound.play", "src": "{sfx.src}", "volume": 0.8 }
      ]
    },
    {
      "command": "!hello",
      "aliases": ["!hi"],
      "roles": ["everyone"],
      "cooldownScope": "user",
      "cooldownSeconds": 30,
      "actions": [
        { "type": "chat.say", "message": "Hey {displayName}.", "reply": true }
      ]
    }
  ],
  "chatEntries": [
    {
      "name": "mod-or-vip-entry",
      "match": {
        "roles": ["moderator", "vip"]
      },
      "actions": [
        { "type": "context.pickRandom", "contextKey": "greeting" },
        { "type": "overlay.alert", "message": "{greeting}, {displayName}!" },
        { "type": "sound.play", "src": "example.mp3", "volume": 1 }
      ]
    }
  ],
  "redemptions": [
    {
      "name": "hydrate",
      "match": {
        "rewardTitle": "Hydrate"
      },
      "cooldownScope": "user",
      "cooldownSeconds": 10,
      "actions": [
        { "type": "overlay.alert", "message": "{displayName} redeemed {reward.title}: {redemption.input}" },
        { "type": "chat.say", "message": "Thanks for the {reward.title}, {displayName}!" }
      ]
    },
    {
      "name": "song-request",
      "match": {
        "rewardId": "replace_with_twitch_reward_id",
        "inputContains": "http"
      },
      "actions": [
        { "type": "overlay.alert", "message": "{displayName} requested: {redemption.input}" }
      ]
    },
    {
      "name": "sfx-random",
      "match": {
        "rewardTitle": "SFX // RANDOM"
      },
      "actions": [
        { "type": "sound.pickRandom", "contextKey": "sfx" },
        { "type": "overlay.alert", "message": "{sfx.text}" },
        { "type": "sound.play", "src": "{sfx.src}", "volume": 1 }
      ]
    }
  ],
  "follows": [
    {
      "name": "new-follower",
      "cooldownScope": "user",
      "cooldownSeconds": 10,
      "actions": [
        { "type": "overlay.alert", "message": "Welcome in, {displayName}! Thanks for the follow." },
        { "type": "chat.say", "message": "Welcome in, {displayName}! Thanks for following." }
      ]
    }
  ],
  "raids": [
    {
      "name": "incoming-raid",
      "actions": [
        { "type": "overlay.alert", "message": "{displayName} raided with {raid.viewers} viewers!" },
        { "type": "chat.say", "message": "Huge welcome to {displayName}'s crew. Thanks for the raid!" }
      ]
    },
    {
      "name": "big-raid",
      "match": {
        "minViewers": 25
      },
      "actions": [
        { "type": "overlay.alert", "message": "BIG RAID: {displayName} brought {raid.viewers} viewers!" },
        { "type": "sound.play", "src": "example.mp3", "volume": 1 }
      ]
    }
  ],
  "subscriptions": [
    {
      "name": "new-sub",
      "match": {
        "event": "subscription.add"
      },
      "actions": [
        { "type": "overlay.alert", "message": "{displayName} subscribed at tier {subscription.tier}!" },
        { "type": "chat.say", "message": "Thanks for subscribing, {displayName}!" }
      ]
    },
    {
      "name": "gift-sub",
      "match": {
        "event": "subscription.gift"
      },
      "actions": [
        { "type": "overlay.alert", "message": "{displayName} gifted {subscription.amount} tier {subscription.tier} subs!" },
        { "type": "chat.say", "message": "Thank you for gifting {subscription.amount} subs, {displayName}!" }
      ]
    }
  ]
}
