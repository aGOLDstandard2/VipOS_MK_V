<%- include("templates/header") %>

<main id="control-panel">
  <header class="control-header">
    <div>
      <h1><%= appName %></h1>
      <p><%= appDescription %></p>
    </div>
    <div id="service-status" data-status>Loading</div>
  </header>

  <section class="control-grid">
    <div class="control-section">
      <h2>Overlays</h2>
      <form data-json-form data-endpoint="/api/v1/alert">
        <label for="alert-message">Text alert</label>
        <div class="control-row">
          <input id="alert-message" name="message" type="text" autocomplete="off" />
          <button type="submit">Send</button>
        </div>
      </form>
      <div class="button-row">
        <button type="button" data-post="/api/v1/bg-alert">Alert</button>
        <button type="button" data-post="/api/v1/bg-random">Random Border</button>
        <button type="button" data-post="/api/v1/bg-reset">Reset Border</button>
        <button type="button" data-post="/api/v1/test">Test Text Alert</button>
      </div>
    </div>

    <div class="control-section">
      <h2>OBS</h2>
      <form data-json-form data-endpoint="/api/v1/obs/scene">
        <label for="obs-scene">Scene</label>
        <div class="control-row">
          <input id="obs-scene" name="scene" type="text" autocomplete="off" />
          <button type="submit">Switch</button>
        </div>
      </form>
      <form data-json-form data-endpoint="/api/v1/obs/mute">
        <label for="obs-input">Audio input</label>
        <div class="control-row">
          <input id="obs-input" name="input" type="text" autocomplete="off" />
          <select name="muted">
            <option value="toggle">Toggle</option>
            <option value="true">Mute</option>
            <option value="false">Unmute</option>
          </select>
          <button type="submit">Apply</button>
        </div>
      </form>
    </div>

    <div class="control-section">
      <h2>Sound</h2>
      <form data-json-form data-endpoint="/api/v1/sound">
        <label for="sound-src">Source path</label>
        <div class="control-row">
          <input id="sound-src" name="src" type="text" placeholder="example.mp3" autocomplete="off" />
          <input name="volume" type="number" min="0" max="1" step="0.05" value="1" />
          <button type="submit">Play</button>
        </div>
      </form>
    </div>
    <!--
    TO-DO: Implement chat message sending via API (requires Twitch bot to be connected)
    <div class="control-section">
      <h2>Chat</h2>
      <form data-json-form data-endpoint="/api/v1/chat/say">
        <label for="chat-message">Message</label>
        <div class="control-row">
          <input id="chat-message" name="message" type="text" autocomplete="off" />
          <button type="submit">Say</button>
        </div>
      </form>
    </div>
    -->
  </section>

  <pre id="control-log" aria-live="polite"></pre>
</main>

<script type="text/javascript" src="/assets/js/control.js"></script>

<%- include("templates/footer") %>
