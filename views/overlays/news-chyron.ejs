<%- include("../templates/header") %>

<%
const initialChyronItem = chyronItems[0];
%>

<div id="chyron-container">
  <div id="chyron">
    <div id="logo-box"></div>

    <div id="chyron-text">
      <div id="chyron-title">
        <h3 id="chyron-title-text"><%= initialChyronItem.h3 %></h3>
      </div>
      <div id="chyron-header">
        <h1 id="chyron-headline-text"><%= initialChyronItem.h1 %></h1>
        <h2 id="chyron-subhead-text"><%= initialChyronItem.h2 %></h2>
      </div>
    </div>

  </div>
</div>

<script>
  (() => {
    const items = <%- chyronItemsJson %>;
    const rotateIntervalMs = <%- JSON.stringify(chyronRotateIntervalMs) %>;
    const title = document.getElementById('chyron-title-text');
    const headline = document.getElementById('chyron-headline-text');
    const subhead = document.getElementById('chyron-subhead-text');
    const chyronText = document.getElementById('chyron-text');
    const fadeDurationMs = 500;
    let currentIndex = 0;

    if (!title || !headline || !subhead || !chyronText || items.length < 2 || rotateIntervalMs <= 0) return;

    function getNextIndex() {
      let nextIndex = Math.floor(Math.random() * items.length);
      if (nextIndex === currentIndex) nextIndex = (nextIndex + 1) % items.length;
      return nextIndex;
    }

    function renderItem(item) {
      title.textContent = item.h3;
      headline.textContent = item.h1;
      subhead.textContent = item.h2;
    }

    function transitionToItem(item) {
      chyronText.classList.add('is-fading');

      window.setTimeout(() => {
        renderItem(item);
        window.requestAnimationFrame(() => {
          chyronText.classList.remove('is-fading');
        });
      }, fadeDurationMs);
    }

    window.setInterval(() => {
      currentIndex = getNextIndex();
      transitionToItem(items[currentIndex]);
    }, rotateIntervalMs);
  })();
</script>

<%- include("../templates/footer") %>
