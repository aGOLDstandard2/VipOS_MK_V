<%- include("../templates/header") %>

<%
const initialChyronIndex = Math.floor(Math.random() * chyronItems.length);
const initialChyronItem = chyronItems[initialChyronIndex];
%>

<div id="chyron-container">
  <div
    id="chyron"
    data-lower-third
    style="--lower-third-slide-distance: <%= lowerThirdSlideDistance %>; --lower-third-slide-duration: <%= lowerThirdSlideDuration %>;"
  >
    <div id="logo-box"></div>

    <div id="chyron-text">
      <div id="chyron-title">
        <h3 id="chyron-title-text"><%= initialChyronItem.h3 %></h3>
      </div>
      <div id="chyron-header">
        <h1 id="chyron-headline-text"><%= initialChyronItem.h1 %></h1>
        <h2 id="chyron-subhead-text"><%= initialChyronItem.h2 %></h2>
      </div>
    </div>

  </div>
</div>

<script>
  (() => {
    const items = <%- chyronItemsJson %>;
    const rotateIntervalMs = <%- JSON.stringify(chyronRotateIntervalMs) %>;
    const chyron = document.getElementById('chyron');
    const title = document.getElementById('chyron-title-text');
    const headline = document.getElementById('chyron-headline-text');
    const subhead = document.getElementById('chyron-subhead-text');
    const chyronText = document.getElementById('chyron-text');
    const fadeDurationMs = 500;
    const chyronItemsMax = items.length;
    let currentIndex = 0;
    const usedItems = [];

    if (!title || !headline || !subhead || !chyronText || items.length < 2 || rotateIntervalMs <= 0) return;

    chyron.animate({width: '48%'}, {duration: fadeDurationMs, fill: 'forwards'});

    function chyronHandler() {
      if (items.length === 0) {
        chyron.animate({width: '0'}, {duration: fadeDurationMs, fill: 'forwards'});
        for (let i = 0; i < usedItems.length; i++) {
          items.push(usedItems[i]);
        }
        usedItems.length = 0;
        window.setTimeout(() => {
          chyron.animate({width: '48%'}, {duration: fadeDurationMs, fill: 'forwards'});
        }, rotateIntervalMs * 2);
        return true;
      }
      return false;
    }

    function renderItem(item) {
      if (!item || !item.h3) return;
      title.textContent = item.h3;
      headline.textContent = item.h1;
      subhead.textContent = item.h2;
    }

    function transitionToItem(item) {
      chyronText.classList.add('is-fading');
      window.setTimeout(() => {
        renderItem(item);
        window.requestAnimationFrame(() => {
          chyronText.classList.remove('is-fading');
        });
      }, fadeDurationMs);
    }

    function triggerNext() {
      if (chyronHandler()) return;
      currentIndex = Math.floor(Math.random() * items.length);
      const selectedItem = items[currentIndex];
      usedItems.push(selectedItem);
      items.splice(currentIndex, 1);
      transitionToItem(selectedItem);
    }

    triggerNext();

    window.setInterval(triggerNext, rotateIntervalMs);
  })();
</script>
<script type="text/javascript" src="/assets/js/lower-third.js"></script>
<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>

<%- include("../templates/footer") %>
