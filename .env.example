## Copy this file to .env and fill in real values. Do NOT commit your .env file.
# Example environment variables for VipOS MK V

# Server
PORT=5000
NODE_ENV=production
APP_NAME=Your App Name
APP_DESCRIPTION=Super Cool & Witty Description

# OBS ( replace with your OBS WebSocket password )
#     ( Retry interval in milliseconds           )
OBS_ENABLED=true
OBS_ADDRESS=ws://localhost:4455
OBS_PASSWORD=your_obs_password_here
OBS_RECONNECT_RETRY_INTERVAL=5000

# Twitch / Chat ( if using tmi.js or Twurple )
CHAT_ENABLED=true
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

TWITCH_BOT_TOKEN=oauth:your_bot_oauth_token
TWITCH_BOT_USERNAME=your_bot_username
TWITCH_CHANNEL=your_channel_name

# Chat highlight alerts
CHAT_ENABLE_HIGHLIGHT_ALERTS=true
TWITCH_HIGHLIGHT_REWARD_ID=

# Sound files (should be in public/assets/sounds/)
# Not necessary to provide public/assets/sounds/ in the path, just the filename (e.g., "alert.mp3")
DEFAULT_ALERT_SOUND=