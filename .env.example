## Copy this file to .env and fill in real values. Do NOT commit your .env file.
# Example environment variables for VipOS MK V

# Server
PORT=5000
NODE_ENV=production
APP_NAME=Your App Name
APP_DESCRIPTION=Super Cool & Witty Description

# OBS ( replace with your OBS WebSocket password )
OBS_ENABLED=true
OBS_ADDRESS=ws://localhost:4455
OBS_PASSWORD=your_obs_password_here
OBS_RECONNECT_RETRY_INTERVAL=5000

# Twitch / Chat (EventSub WebSocket + Send Chat Message API via Twurple)
CHAT_ENABLED=true
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Authorize your bot account with: user:read:chat user:write:chat
# Prefer access + refresh tokens for long-term use. Refreshed tokens are stored in TWITCH_TOKEN_FILE.
TWITCH_BOT_ACCESS_TOKEN=your_bot_access_token
TWITCH_BOT_REFRESH_TOKEN=your_bot_refresh_token
TWITCH_BOT_SCOPES=user:read:chat user:write:chat
TWITCH_TOKEN_FILE=config/twitch-token.json

# Optional, but avoids one lookup if you know them.
TWITCH_BOT_USER_ID=your_bot_user_id
TWITCH_BOT_USERNAME=your_bot_username

# Main streaming account to listen to. TWITCH_CHANNEL can be a login; TWITCH_CHANNEL_ID is preferred if known.
TWITCH_CHANNEL=your_channel_name
TWITCH_CHANNEL_ID=your_channel_id
CHAT_COMMAND_PREFIX=!
CHAT_COMMANDS_FILE=config/commands.json
CHAT_IGNORE_SELF=true
CHAT_RECONNECT_INITIAL_MS=5000
CHAT_RECONNECT_MAX_MS=60000

# Channel point / reward events require the broadcaster account to authorize one of:
# channel:read:redemptions channel:manage:redemptions
CHAT_ENABLE_REDEMPTIONS=false
TWITCH_BROADCASTER_ACCESS_TOKEN=your_broadcaster_access_token
TWITCH_BROADCASTER_REFRESH_TOKEN=your_broadcaster_refresh_token
TWITCH_BROADCASTER_SCOPES=bits:read channel:read:redemptions channel:manage:redemptions channel:read:polls channel:manage:polls channel:read:predictions channel:manage:predictions channel:read:goals channel:read:hype_train channel:read:subscriptions channel:read:vips channel:read:ads channel:read:charity moderator:read:followers moderator:read:chatters
TWITCH_BROADCASTER_TOKEN_FILE=config/twitch-broadcaster-token.json

# Chat highlight alerts
CHAT_ENABLE_HIGHLIGHT_ALERTS=true
TWITCH_HIGHLIGHT_REWARD_ID=

# Sound files (should be in public/assets/sounds/)
# Not necessary to provide public/assets/sounds/ in the path, just the filename (e.g., "alert.mp3")
DEFAULT_ALERT_SOUND=

# Raffle ( detailed raffle settings live in config/raffle.json )
RAFFLE_ENABLED=false
